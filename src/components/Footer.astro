---
/* Footer — IDENTICAL to family.co
   White bg, no border-top, extremely muted links (40% opacity),
   logo + 3 columns left, copyright + social icons right */

const currentYear = new Date().getFullYear();

const columns = [
  {
    title: 'Services',
    links: [
      { label: 'Video Production', href: '/services/video-production' },
      { label: 'Motion Graphics', href: '/services/motion-graphics' },
      { label: 'Graphic Design', href: '/services/graphic-design' },
      { label: 'Animation', href: '/services/animation' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'How it works', href: '#how-it-works' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'Blog', href: '/blog' },
      { label: 'FAQs', href: '#faq' },
      { label: 'Press Kit', href: '/press' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'Contact', href: 'mailto:hello@moonb.io' },
      { label: 'X (Twitter)', href: 'https://x.com/moonb_creative' },
      { label: 'Legal', href: '/legal' },
    ],
  },
];
---

<footer class="footer">
  <div class="footer__inner">

    <div class="footer__main">
      <!-- Left: logo + columns -->
      <div class="footer__left">
        <a href="/" class="footer__logo" aria-label="Moonb homepage">
          <img src="/assets/logos/moonbee-icon.svg" alt="" width="24" height="24" style="opacity: 0.4;" />
        </a>

        {columns.map((col) => (
          <div class="footer__col">
            <h5 class="footer__col-title">{col.title}</h5>
            <ul class="footer__col-list">
              {col.links.map((link) => (
                <li><a href={link.href} class="footer__col-link">{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Right: copyright + social icons + badges -->
      <div class="footer__right">
        <span class="footer__copy">&copy; {currentYear}</span>
        <div class="footer__socials">
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/company/moonb-creative/" class="footer__social" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <!-- X -->
          <a href="https://x.com/moonb_creative" class="footer__social" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <!-- Email -->
          <a href="mailto:hello@moonb.io" class="footer__social" aria-label="Email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
          </a>
        </div>
        <div class="footer__badges">
          <a href="https://clutch.co/profile/moonb#reviews" target="_blank" rel="noopener noreferrer" aria-label="Clutch Global Award Spring 2024">
            <img src="https://cdn.prod.website-files.com/64bab9d8647370067fbace0b/66782dd82e87d83e5ea456a2_global_award_spring_2024.svg" alt="Clutch Global Award Spring 2024" width="40" height="40" loading="lazy" />
          </a>
          <a href="https://clutch.co/profile/moonb#reviews" target="_blank" rel="noopener noreferrer" aria-label="Top 100 Video Production Companies">
            <img src="https://cdn.prod.website-files.com/64bab9d8647370067fbace0b/682b6bdce36d0f3648b6ab13_Badge-Image.svg" alt="Top 100 Video Production Companies" width="40" height="40" loading="lazy" />
          </a>
          <a href="https://clutch.co/profile/moonb#reviews" target="_blank" rel="noopener noreferrer" aria-label="Clutch Top Video Production Company 2025">
            <img src="https://cdn.prod.website-files.com/64bab9d8647370067fbace0b/691aec61d3ce866726972a31_Clutch-2025.svg" alt="Clutch Top Video Production 2025" width="40" height="40" loading="lazy" />
          </a>
          <a href="https://50pros.com" target="_blank" rel="noopener noreferrer" aria-label="Global Leader Top 10 Creative Production 2026">
            <img src="/assets/badges/2026-badge.svg" alt="Global Leader Top 10 2026" width="40" height="40" loading="lazy" />
          </a>
        </div>
      </div>
    </div>

  </div>
</footer>

<style>
  /* Footer — family.co exact style: white, extremely muted */
  .footer {
    background: var(--white);
    padding: 68px 0 96px;
  }

  .footer__inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer__main {
    display: flex;
    justify-content: space-between;
  }

  /* Left side: logo + 3 columns */
  .footer__left {
    display: flex;
    gap: 60px;
  }

  .footer__logo {
    flex-shrink: 0;
  }

  .footer__col-title {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--heading);
    margin-bottom: 14px;
    letter-spacing: 0;
  }

  .footer__col-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .footer__col-link {
    font-size: 13px;
    font-weight: 400;
    color: rgba(34, 34, 34, 0.4);
    transition: color 140ms ease;
  }

  .footer__col-link:hover {
    color: var(--heading);
  }

  /* Right side: copyright + social icons, aligned to bottom-right */
  .footer__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 13px;
  }

  .footer__copy {
    font-size: 13px;
    font-weight: 400;
    color: rgba(112, 112, 112, 0.4);
  }

  .footer__socials {
    display: flex;
    gap: 13px;
  }

  .footer__social {
    color: rgba(112, 112, 112, 0.4);
    transition: color 140ms ease;
  }

  .footer__social:hover {
    color: var(--heading);
  }

  .footer__social svg {
    display: block;
  }

  .footer__badges {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    opacity: 0.4;
    transition: opacity 200ms ease;
  }

  .footer__badges:hover {
    opacity: 0.7;
  }

  .footer__badges img {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  @media (max-width: 860px) {
    .footer__main {
      flex-direction: column;
      gap: 48px;
    }

    .footer__left {
      flex-wrap: wrap;
      gap: 40px;
    }

    .footer__right {
      align-items: flex-start;
      flex-direction: row;
      justify-content: space-between;
    }
  }

  @media (max-width: 480px) {
    .footer__left {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>
