---
const links = [
  { label: 'Services', href: '/services', hasDropdown: true },
  { label: 'Work', href: '#work' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
];

/* 4 items like Aave's 4 products — single column, branded icons */
const dropdownItems = [
  {
    label: 'Video Production',
    desc: 'Corporate, marketing, social, branded.',
    href: '/services/corporate-video-production',
    gradient: 'linear-gradient(135deg, #FF5310 0%, #FF8A65 100%)',
    iconColor: '#fff',
  },
  {
    label: 'Motion & Animation',
    desc: 'Explainers, 2D/3D, product, motion.',
    href: '/services/motion-graphics',
    gradient: 'linear-gradient(135deg, #0066FF 0%, #5C9AFF 100%)',
    iconColor: '#fff',
  },
  {
    label: 'Graphic Design',
    desc: 'Brand, social, print, presentations.',
    href: '/services/graphic-design',
    gradient: 'linear-gradient(135deg, #00B67A 0%, #4FD9A6 100%)',
    iconColor: '#fff',
  },
  {
    label: 'Industry Solutions',
    desc: 'SaaS, finance, healthcare, e-commerce.',
    href: '/industries/saas-video-production',
    gradient: 'linear-gradient(135deg, #7B61FF 0%, #A78BFA 100%)',
    iconColor: '#fff',
  },
];
---

<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label="Moonb homepage">
      <img src="/assets/logos/moonbee-icon.svg" alt="" class="nav__logo-icon" width="28" height="28" />
      <span class="nav__wordmark">moonb</span>
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      {links.map((link) => (
        link.hasDropdown ? (
          <div class="nav__dropdown-wrap">
            <button class="nav__link nav__link--trigger" type="button">
              {link.label}
              <svg class="nav__arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="nav__dropdown">
              <div class="nav__dropdown-card">
                {dropdownItems.map((item) => (
                  <a href={item.href} class="nav__dd-item">
                    <div class="nav__dd-icon" style={`background: ${item.gradient}`}>
                      {item.label === 'Video Production' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={item.iconColor} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                      )}
                      {item.label === 'Motion & Animation' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={item.iconColor} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                      )}
                      {item.label === 'Graphic Design' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={item.iconColor} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                      )}
                      {item.label === 'Industry Solutions' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={item.iconColor} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l5-4 5 4v12"/><path d="M9 20v-4h2v4"/><path d="M15 20V12l5-2v10"/></svg>
                      )}
                    </div>
                    <div class="nav__dd-text">
                      <span class="nav__dd-label">{item.label}</span>
                      <span class="nav__dd-desc">{item.desc}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={link.href} class="nav__link">{link.label}</a>
        )
      ))}
    </nav>

    <a href="#" class="nav__cta" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>
      Book a Call
    </a>

    <button class="nav__toggle" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
      <span></span><span></span>
    </button>
  </div>
</header>

<div class="nav-mobile" id="mobile-menu" aria-hidden="true">
  {links.map((link) => (
    <a href={link.href} class="nav-mobile__link">{link.label}</a>
  ))}
  <a href="#" class="nav-mobile__cta" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>
    Book a Call
  </a>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    background: var(--white);
    transition: background 300ms ease;
  }

  .nav.is-scrolled {
    background: var(--white);
    box-shadow: 0 1px 0 rgba(0,0,0,0.04);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    max-width: calc(var(--max-w) + 6rem);
    margin: 0 auto;
    padding: 0 1.5rem;
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    margin-right: 2rem;
  }

  .nav__logo-icon { width: 26px; height: 26px; }

  .nav__wordmark {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    color: var(--heading);
    letter-spacing: -0.04em;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    color: var(--heading);
    padding: 8px 14px;
    transition: color 140ms ease;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav__link:hover { color: var(--body-muted); }

  /* Trigger pill — like Aave "Products" gets a border on hover */
  .nav__link--trigger {
    border-radius: 9999px;
    border: 1.5px solid transparent;
    transition: border-color 200ms ease, color 140ms ease;
  }

  .nav__dropdown-wrap:hover .nav__link--trigger {
    border-color: rgba(0, 0, 0, 0.12);
  }

  .nav__arrow {
    width: 10px;
    height: 6px;
    opacity: 0.45;
    transition: transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav__dropdown-wrap:hover .nav__arrow {
    transform: rotate(180deg);
  }

  /* ── Dropdown — Aave liquid animation ── */
  .nav__dropdown-wrap {
    position: relative;
  }

  .nav__dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%);
    padding-top: 12px;
    pointer-events: none;
  }

  .nav__dropdown-card {
    background: var(--white);
    border-radius: 20px;
    padding: 8px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    min-width: 280px;

    /* Aave liquid: starts scaled down + faded + shifted up */
    opacity: 0;
    transform: translateY(8px) scale(0.95);
    transform-origin: top center;
    transition:
      opacity 220ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav__dropdown-wrap:hover .nav__dropdown {
    pointer-events: auto;
  }

  .nav__dropdown-wrap:hover .nav__dropdown-card {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ── Items — single column, no dividers ── */
  .nav__dd-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 14px;
    transition: background 150ms ease;
    text-decoration: none;
  }

  .nav__dd-item:hover {
    background: rgba(0, 0, 0, 0.03);
  }

  /* Branded gradient icons — colored bg, white stroke */
  .nav__dd-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav__dd-item:hover .nav__dd-icon {
    transform: scale(1.06);
  }

  .nav__dd-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav__dd-label {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--heading);
    letter-spacing: -0.2px;
  }

  .nav__dd-desc {
    font-size: 13px;
    color: var(--body-muted);
    line-height: 1.3;
  }

  /* ── CTA ── */
  .nav__cta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    padding: 0 14px;
    background: #171717;
    color: #FFFFFF;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.22px;
    border-radius: 32px;
    transition: background-color 250ms ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav__cta:hover { background: #3a3a3a; }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav__toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--heading);
    border-radius: 1px;
  }

  .nav-mobile {
    display: none;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    z-index: calc(var(--z-nav) - 1);
    background: var(--white);
    padding: 8px 24px 24px;
    flex-direction: column;
    gap: 2px;
  }

  .nav-mobile.is-open { display: flex; }

  .nav-mobile__link {
    display: block;
    padding: 14px 12px;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    color: var(--heading);
    border-radius: var(--r-md);
  }

  .nav-mobile__link:hover { background: var(--beige); }

  .nav-mobile__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 12px;
    height: 40px;
    padding: 0 20px;
    background: #171717;
    color: var(--btn-primary-text);
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.22px;
    border-radius: 32px;
  }

  @media (max-width: 860px) {
    .nav__links { display: none; }
    .nav__cta { display: none; }
    .nav__toggle { display: flex; }
  }
</style>

<script>
  const nav = document.querySelector('.nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('is-scrolled');
    } else {
      nav?.classList.remove('is-scrolled');
    }
  }, { passive: true });

  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
