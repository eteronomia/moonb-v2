---
const links = [
  { label: 'Services', href: '/services', hasDropdown: true },
  { label: 'Work', href: '#work' },
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
];

const serviceItems = [
  { label: 'Video Production', desc: 'Commercials, socials, corporate.', href: '/services/corporate-video-production', icon: 'video' },
  { label: 'Motion Graphics', desc: 'Explainers, intros, branded motion.', href: '/services/motion-graphics', icon: 'motion' },
  { label: 'Animation', desc: '2D, 3D, character, product.', href: '/services/animation', icon: 'animation' },
  { label: 'Graphic Design', desc: 'Brand, social, print, decks.', href: '/services/graphic-design', icon: 'design' },
];
---

<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label="Moonb homepage">
      <img src="/assets/logos/moonbee-icon.svg" alt="" class="nav__logo-icon" width="28" height="28" />
      <span class="nav__wordmark">moonb</span>
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      {links.map((link) => (
        link.hasDropdown ? (
          <div class="nav__dropdown-wrap">
            <a href={link.href} class="nav__link">
              {link.label}
              <svg class="nav__arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav__dropdown">
              <div class="nav__dropdown-inner">
                {serviceItems.map((s) => (
                  <a href={s.href} class="nav__dd-item">
                    <div class={`nav__dd-icon nav__dd-icon--${s.icon}`}>
                      {s.icon === 'video' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                      )}
                      {s.icon === 'motion' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                      )}
                      {s.icon === 'animation' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                      )}
                      {s.icon === 'design' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                      )}
                    </div>
                    <div class="nav__dd-text">
                      <span class="nav__dd-label">{s.label}</span>
                      <span class="nav__dd-desc">{s.desc}</span>
                    </div>
                  </a>
                ))}
                <div class="nav__dd-footer">
                  <a href="/services" class="nav__dd-all">All services <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a href={link.href} class="nav__link">{link.label}</a>
        )
      ))}
    </nav>

    <a href="#" class="nav__cta" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>
      Book a Call
    </a>

    <button class="nav__toggle" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
      <span></span><span></span>
    </button>
  </div>
</header>

<div class="nav-mobile" id="mobile-menu" aria-hidden="true">
  {links.map((link) => (
    <a href={link.href} class="nav-mobile__link">{link.label}</a>
  ))}
  <a href="#" class="nav-mobile__cta" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>
    Book a Call
  </a>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    background: var(--white);
    transition: background 300ms ease;
  }

  .nav.is-scrolled {
    background: var(--white);
    box-shadow: 0 1px 0 rgba(0,0,0,0.04);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    max-width: calc(var(--max-w) + 6rem);
    margin: 0 auto;
    padding: 0 1.5rem;
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    margin-right: 2rem;
  }

  .nav__logo-icon { width: 26px; height: 26px; }

  .nav__wordmark {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    color: var(--heading);
    letter-spacing: -0.04em;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    color: var(--heading);
    padding: 8px 14px;
    transition: color 140ms ease;
    white-space: nowrap;
  }

  .nav__link:hover { color: var(--body-muted); }

  .nav__arrow {
    width: 10px;
    height: 6px;
    opacity: 0.5;
    transition: transform 250ms cubic-bezier(0.19, 1, 0.22, 1);
  }

  /* ── Dropdown — Aave style ── */
  .nav__dropdown-wrap {
    position: relative;
  }

  .nav__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 16px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 200ms cubic-bezier(0.19, 1, 0.22, 1),
                visibility 200ms cubic-bezier(0.19, 1, 0.22, 1);
  }

  .nav__dropdown-inner {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--white);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    padding: 8px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.02);
    min-width: 320px;
    transform: translateY(4px) scale(0.98);
    transition: transform 250ms cubic-bezier(0.19, 1, 0.22, 1);
  }

  .nav__dropdown-wrap:hover .nav__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .nav__dropdown-wrap:hover .nav__dropdown-inner {
    transform: translateY(0) scale(1);
  }

  .nav__dropdown-wrap:hover .nav__arrow {
    transform: rotate(180deg);
  }

  /* Dropdown items — Aave card style */
  .nav__dd-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 14px;
    transition: background 160ms ease;
  }

  .nav__dd-item:hover {
    background: var(--beige);
  }

  /* Rounded icon containers */
  .nav__dd-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #F3F3F3;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #666;
    transition: background 160ms ease, color 160ms ease;
  }

  .nav__dd-item:hover .nav__dd-icon--video {
    background: rgba(255, 83, 16, 0.1);
    color: var(--accent);
  }
  .nav__dd-item:hover .nav__dd-icon--motion {
    background: rgba(0, 102, 255, 0.1);
    color: var(--accent-blue);
  }
  .nav__dd-item:hover .nav__dd-icon--animation {
    background: rgba(123, 97, 255, 0.1);
    color: var(--accent-purple);
  }
  .nav__dd-item:hover .nav__dd-icon--design {
    background: rgba(0, 182, 122, 0.1);
    color: var(--accent-green);
  }

  .nav__dd-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav__dd-label {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--heading);
    letter-spacing: -0.2px;
  }

  .nav__dd-desc {
    font-size: 13px;
    color: var(--body-muted);
    line-height: 1.3;
  }

  /* Footer link */
  .nav__dd-footer {
    border-top: 1px solid rgba(0,0,0,0.05);
    margin-top: 4px;
    padding-top: 4px;
  }

  .nav__dd-all {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-radius: 12px;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 500;
    color: var(--body-muted);
    transition: color 140ms ease, background 140ms ease;
  }

  .nav__dd-all:hover {
    color: var(--heading);
    background: var(--beige);
  }

  /* ── CTA ── */
  .nav__cta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    padding: 0 14px;
    background: #171717;
    color: #FFFFFF;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.22px;
    border-radius: 32px;
    transition: background-color 250ms ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav__cta:hover { background: #3a3a3a; }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav__toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--heading);
    border-radius: 1px;
  }

  .nav-mobile {
    display: none;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    z-index: calc(var(--z-nav) - 1);
    background: var(--white);
    padding: 8px 24px 24px;
    flex-direction: column;
    gap: 2px;
  }

  .nav-mobile.is-open { display: flex; }

  .nav-mobile__link {
    display: block;
    padding: 14px 12px;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    color: var(--heading);
    border-radius: var(--r-md);
  }

  .nav-mobile__link:hover { background: var(--beige); }

  .nav-mobile__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 12px;
    height: 40px;
    padding: 0 20px;
    background: #171717;
    color: var(--btn-primary-text);
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.22px;
    border-radius: 32px;
  }

  @media (max-width: 860px) {
    .nav__links { display: none; }
    .nav__cta { display: none; }
    .nav__toggle { display: flex; }
  }
</style>

<script>
  // Nav scroll
  const nav = document.querySelector('.nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('is-scrolled');
    } else {
      nav?.classList.remove('is-scrolled');
    }
  }, { passive: true });

  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
