---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Your Creative Team | Moonb">

  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__title" data-reveal>
        Your own creative team.
      </h1>

      <p class="hero__sub" data-reveal data-reveal-delay="1">
        Moonb gives you a dedicated team of designers, editors, and motion artists that work as part of your brand. Great work, on repeat.
      </p>

      <div class="hero__actions" data-reveal data-reveal-delay="2">
        <a href="#" class="hero-btn-primary" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>
          Book a Call
        </a>
        <a href="#showreel" class="hero-btn-secondary">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M6 3.5C6 2.67 6.96 2.17 7.64 2.67L15.64 8.67C16.2 9.09 16.2 9.91 15.64 10.33L7.64 16.33C6.96 16.83 6 16.33 6 15.5V3.5Z" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round" stroke-linecap="round"/>
          </svg>
          Watch the Video
        </a>
      </div>
    </div>

  </section>

</BaseLayout>

<style>
  .hero {
    padding-top: 100px;
    padding-bottom: 0;
    background-color: var(--white);
    overflow: hidden;
  }

  .hero__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero__title {
    max-width: 700px;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--heading);
  }

  .hero__sub {
    max-width: 520px;
    margin-top: 18px;
    font-size: 17px;
    line-height: 27px;
    letter-spacing: -0.22px;
    color: var(--body);
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 28px;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 88px;
    }

    .hero__title {
      font-size: 40px;
      letter-spacing: -1.2px;
      line-height: 44px;
    }

    .hero__sub {
      font-size: 16px;
      line-height: 24px;
    }

    .hero__actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-btn-primary,
    .hero-btn-secondary {
      width: 100%;
      justify-content: center;
    }

    .hero__devices {
      gap: 12px;
      margin-top: 40px;
    }

    .device--phone { width: 90px; }
    .device--laptop { width: 200px; }
    .device--tablet { width: 100px; }
  }

  @media (max-width: 480px) {
    .hero__title {
      font-size: 34px;
      line-height: 38px;
    }

    .device--phone { width: 70px; }
    .device--laptop { width: 160px; }
    .device--tablet { width: 80px; }
  }
</style>
