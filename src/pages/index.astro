---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

/* Roles for "Made for" section */
const roles = [
  { name: 'Creative Directors', desc: 'Your vision, our execution. A dedicated team that turns creative direction into polished deliverables — fast.', color: 'purple' },
  { name: 'Marketing Leaders', desc: 'Never miss a campaign deadline. Continuous creative output aligned with your marketing calendar.', color: 'blue' },
  { name: 'Founders', desc: 'World-class creative without the overhead of building an in-house team. Scale up or down as you grow.', color: 'green' },
  { name: 'Brand Managers', desc: 'Consistent brand identity across every touchpoint. One team that knows your guidelines inside out.', color: 'purple' },
  { name: 'Content Teams', desc: 'Multiply your output without multiplying your headcount. Video, design, and motion on demand.', color: 'green' },
  { name: 'Product Teams', desc: 'Launch videos, product demos, feature announcements, and onboarding content — always ready for the next release.', color: 'blue' },
];

/* Services */
const services = [
  { title: 'Video Production', description: 'From commercials to social content. A dedicated team producing video that moves audiences.', tag: 'Video' },
  { title: 'Motion Graphics', description: 'Animated explainers, product demos, and branded motion. Bring your message to life.', tag: 'Motion' },
  { title: 'Graphic Design', description: 'Brand identities, social media, presentations, and print. Design that stands out.', tag: 'Design' },
  { title: 'Animation', description: '2D and 3D animation for campaigns, product launches, and storytelling.', tag: 'Animation' },
];

/* Feature items for "Details that matter" sticky section */
const details = [
  { label: 'Your Creative Director', title: 'One person who knows your brand inside out.', desc: 'A strategic partner who learns your voice, your goals, and your audience. Not a revolving door of freelancers.' },
  { label: 'Lightning Turnaround', title: 'Multiple deliveries every week.', desc: 'No bottlenecks, no waiting. Your dedicated team moves fast because they already know what you need.' },
  { label: 'Predictable Investment', title: 'One monthly rate, no surprises.', desc: 'No scope creep, no hidden fees, no surprise invoices. Just great work, consistently delivered.' },
  { label: 'Quality at Scale', title: 'From one social post to a full campaign.', desc: 'Consistent quality whether you need one deliverable or fifty. Your team scales with you.' },
];

/* Feature checklist for phone mockup section */
const checklistItems = ['Dedicated Creative Director', 'Real-time Project Tracking', 'Unlimited Revisions', 'Full File Ownership'];

/* How it works */
const steps = [
  { number: '01', title: 'Get onboarded', description: 'Sign up and meet your dedicated Creative Director on a call. We learn your brand, your goals, and your voice.' },
  { number: '02', title: 'Request anything', description: 'Submit creative requests through our platform. Videos, designs, animations. Your CD prioritizes and plans the work.' },
  { number: '03', title: 'Review and approve', description: 'Receive polished deliverables within days. Review, request revisions, and approve. Repeat.' },
];

/* Testimonials / "Friends of Moonb" */
const reviews = [
  { name: 'Rene Ugarte', role: 'Senior Producer', company: 'MOI', quote: 'They were capable of adapting to fast delivery deadlines. Moonb has become an essential part of our creative workflow.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821ba1672a50268f140277f_Rene%20Ugarte.avif' },
  { name: 'Marius Godo', role: 'Content Specialist', company: 'Gnosis', quote: 'Their creative flair and dedication to getting the animation and storytelling style right are impressive.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b9dc6aa65e5d0a7ebe4e_Marius%20Godo.avif' },
  { name: 'Josh Kirshman', role: 'Director of Marketing', company: 'Frame', quote: 'This was the best experience we have had with a large project like this. Highly recommend.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b8fbc31af3dd6d055791_Josh%20Kirshman.avif' },
  { name: 'James Pais', role: 'Creative Service Director', company: 'Jumo Health', quote: 'My team really enjoyed working with Moonb and found the experience pretty seamless.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b8b403f0791e7f30ab66_James%20Pais.avif' },
  { name: 'Jesse Jankewicz', role: 'Director of Video', company: 'Unobravo', quote: 'The team is highly creative, talented, and eager to deliver above and beyond expectations.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b8619881dbbdd76b062d_Jesse%20Jankewitz.avif' },
  { name: 'Danila De Stefano', role: 'CEO', company: 'Unobravo', quote: 'Their imagination, creativity, precision, and quality of work were impressive.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b7a8db29c755d2647f56_Danilla%20De%20Stefano.avif' },
  { name: 'Jacey Crawford', role: 'Content Manager', company: 'BAM', quote: 'Moonb delivered very high-quality work and the team was a pleasure to work with.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b94772a50268f13f7e1a_Jacey%20Crawford.avif' },
  { name: 'Diane Bizzle', role: 'Art Director', company: 'Brainfuse', quote: 'The ability to quickly understand and adapt to the company branding was impressive.', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b9834fa6be14f2cadf8f_Diana%20Weltzer.avif' },
];

/* Blog posts */
const blogPosts = [
  { title: 'Best Superside alternatives for creative teams', date: 'Published 15 March, 2026', excerpt: 'Looking for a Superside alternative? We compare the top creative production services for teams that need quality, speed, and a dedicated creative partner.', href: '/blog/superside-alternatives' },
  { title: 'The complete guide to video production', date: 'Published 2 February, 2026', excerpt: 'Everything you need to know about producing professional video content, from planning to post-production and distribution.', href: '/blog/video-production-guide' },
];

/* FAQ */
const faqs = [
  { q: "Who is Moonb for?", a: "Marketing directors, creative directors, founders, and teams who need exceptional creative output but don't have the time or resources to build an internal department." },
  { q: "Why choose Moonb over hiring internally?", a: "Building an internal creative department takes months and comes with substantial fixed costs. With Moonb, you get immediate, high-quality creative output and total flexibility for less than the cost of a single senior creative hire." },
  { q: "What types of projects can Moonb handle?", a: "Almost everything creative: video production, motion graphics, animation (2D and 3D), graphic design, branding, and strategic creative consultation." },
  { q: "What does onboarding look like?", a: "Sign up and you'll receive access to our production platform within minutes. Your dedicated Creative Director will contact you immediately to schedule a kickoff call." },
  { q: "Will I own the work?", a: "Absolutely. You receive all working files and own all intellectual property created. It's your work, made by your team." },
];
---

<BaseLayout title="Your Creative Team | Moonb">

  <!-- ═══════ HERO ═══════ -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__title" data-reveal>Your own creative team.</h1>
      <p class="hero__sub" data-reveal data-reveal-delay="1">
        A dedicated team of designers, editors, and motion artists<br/>
        that works as part of your brand. Great work, on repeat.
      </p>
      <div class="hero__actions" data-reveal data-reveal-delay="2">
        <button type="button" class="btn btn--secondary" data-showreel-trigger>
          <svg class="play-icon" width="12" height="14" viewBox="0 0 12 14" fill="none" aria-hidden="true">
            <path d="M1 1.5C1 0.7 1.9 0.2 2.6 0.6L11 5.8C11.6 6.2 11.6 7.1 11 7.5L2.6 12.7C1.9 13.1 1 12.6 1 11.8V1.5Z" fill="currentColor" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
          </svg>
          Showreel
        </button>
      </div>
    </div>
  </section>


  <!-- ═══════ MADE FOR — right after hero for scroll incentive ═══════ -->
  <section class="madefor section">
    <div class="container">
      <div class="madefor__inner">
        <div class="madefor__left" data-reveal>
          <h2 class="section-heading">Made for the people<br/>who build brands.</h2>
          <p class="section-sub">Whether you lead creative, run marketing, or founded the company, Moonb becomes your team.</p>
          <div class="madefor__pills">
            {roles.map((role, i) => (
              <button
                class={`madefor__pill madefor__pill--${role.color}${i === 1 ? ' is-active' : ''}`}
                data-madefor-pill={String(i)}
              >{role.name}</button>
            ))}
          </div>
        </div>
        <div class="madefor__right" data-reveal data-reveal-delay="1">
          {roles.map((role, i) => (
            <div class={`madefor__card madefor__card--${role.color}${i === 1 ? ' is-active' : ''}`} data-madefor-card={String(i)}>
              <span class="madefor__card-role">{role.name}</span>
              <p class="madefor__card-desc">{role.desc}</p>
              <div class="placeholder placeholder--madefor"><span class="placeholder__label">Illustration: {role.name}</span></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    const pills = document.querySelectorAll('[data-madefor-pill]');
    const cards = document.querySelectorAll('[data-madefor-card]');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const idx = pill.getAttribute('data-madefor-pill');
        pills.forEach(p => p.classList.remove('is-active'));
        cards.forEach(c => c.classList.remove('is-active'));
        pill.classList.add('is-active');
        document.querySelector(`[data-madefor-card="${idx}"]`)?.classList.add('is-active');
      });
    });
  </script>


  <!-- ═══════ SERVICES ═══════ -->
  <section class="services section section--beige" id="services">
    <div class="container">
      <h2 class="section-heading" data-reveal>Everything creative, one team.</h2>
      <p class="section-sub" data-reveal data-reveal-delay="1">Video, design, motion, animation. All produced by a team that knows your brand.</p>

      <div class="services__grid">
        {services.map((s, i) => (
          <div class="services__card" data-reveal data-reveal-delay={String(i)}>
            <div class="services__card-visual">
              <div class="placeholder placeholder--service"><span class="placeholder__label">Device mockup: {s.tag} example</span></div>
            </div>
            <div class="services__card-text">
              <span class="services__tag">{s.tag}</span>
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════ FEATURE W/ PHONE MOCKUP — family.co "Wallet activity" style ═══════ -->
  <section class="feature-split section">
    <div class="container">
      <div class="feature-split__inner">
        <div class="feature-split__visual" data-reveal>
          <div class="placeholder placeholder--phone"><span class="placeholder__label">iPhone mockup: Moonb platform dashboard</span></div>
        </div>
        <div class="feature-split__content" data-reveal data-reveal-delay="1">
          <span class="feature-split__label">Your Creative Team</span>
          <h2 class="feature-split__title">Creative output you can understand.</h2>
          <p class="feature-split__desc">Your projects, your team, your timeline. All visible in real-time. No more chasing updates or wondering what's happening next.</p>
          <ul class="feature-split__checklist">
            {checklistItems.map((item) => (
              <li class="feature-split__check">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 10L8.5 13.5L15 7" stroke="#FF5310" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a href="#showreel" class="feature-split__demo">
            <div class="feature-split__demo-thumb">
              <div class="placeholder" style="min-height: 48px; border-radius: 6px;"><span class="placeholder__label" style="font-size: 10px;">Thumb</span></div>
            </div>
            <div class="feature-split__demo-text">
              <span class="feature-split__demo-title">How Moonb Works</span>
              <span class="feature-split__demo-sub">Watch the demo</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════ DETAILS THAT MATTER — family.co sticky section ═══════ -->
  <section class="details section">
    <div class="container">
      <div class="details__inner">
        <div class="details__left">
          <h2 class="details__heading" data-reveal>Details that matter.</h2>
          <p class="details__sub" data-reveal data-reveal-delay="1">We sweat the details, no matter how small.</p>
        </div>
        <div class="details__right">
          {details.map((d, i) => (
            <div class="details__card" data-reveal data-reveal-delay={String(i)}>
              <div class="details__card-visual">
                <div class="placeholder placeholder--detail"><span class="placeholder__label">UI mockup: {d.label}</span></div>
              </div>
              <span class="details__card-label">{d.label}</span>
              <p class="details__card-desc">{d.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════ WORK SHOWCASE ═══════ -->
  <section class="work section" id="work">
    <div class="container">
      <h2 class="section-heading" data-reveal>Work that speaks for itself.</h2>
      <p class="section-sub" data-reveal data-reveal-delay="1">Selected projects from brands we've partnered with.</p>

      <div class="work__grid" data-reveal data-reveal-delay="2">
        <div class="work__item work__item--wide">
          <div class="placeholder placeholder--work-lg"><span class="placeholder__label">MacBook mockup: Featured project</span></div>
          <div class="work__meta"><span class="work__client">Dell Technologies</span><span class="work__type">Video Campaign</span></div>
        </div>
        <div class="work__item">
          <div class="placeholder placeholder--work-sm"><span class="placeholder__label">iPhone mockup: Social content</span></div>
          <div class="work__meta"><span class="work__client">Toyota</span><span class="work__type">Motion Graphics</span></div>
        </div>
        <div class="work__item">
          <div class="placeholder placeholder--work-sm"><span class="placeholder__label">iPhone mockup: Brand animation</span></div>
          <div class="work__meta"><span class="work__client">Microsoft</span><span class="work__type">Animation</span></div>
        </div>
      </div>

      <div class="work__cta" data-reveal><a href="/work" class="btn btn--secondary">See more work</a></div>
    </div>
  </section>


  <!-- ═══════ HOW IT WORKS ═══════ -->
  <section class="howitworks section section--beige" id="how-it-works">
    <div class="container">
      <h2 class="section-heading section-heading--center" data-reveal>Simple to start, easy to love.</h2>

      <div class="howitworks__steps">
        {steps.map((s, i) => (
          <div class="howitworks__step" data-reveal data-reveal-delay={String(i)}>
            <div class="howitworks__step-illust">
              <div class="placeholder placeholder--step"><span class="placeholder__label">Illustration: Step {s.number}</span></div>
            </div>
            <span class="howitworks__number">{s.number}</span>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════ STATS ═══════ -->
  <section class="stats section">
    <div class="container">
      <div class="stats__grid" data-reveal>
        <div class="stats__item"><span class="stats__number">500+</span><span class="stats__label">Projects delivered</span></div>
        <div class="stats__item"><span class="stats__number">95%</span><span class="stats__label">Client retention</span></div>
        <div class="stats__item"><span class="stats__number">48h</span><span class="stats__label">Average turnaround</span></div>
        <div class="stats__item"><span class="stats__number">23+</span><span class="stats__label">Brands trust Moonb</span></div>
      </div>
    </div>
  </section>


  <!-- ═══════ SHOWREEL ═══════ -->
  <section class="showreel section" id="showreel">
    <div class="container" data-reveal>
      <div class="showreel__wrap">
        <iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&title=0&byline=0&portrait=0" width="100%" height="100%" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy" title="Moonb Showreel"></iframe>
      </div>
    </div>
  </section>


  <!-- ═══════ FRIENDS OF MOONB — tweet cards like family.co ═══════ -->
  <section class="reviews section">
    <div class="container">
      <div class="reviews__header" data-reveal>
        <h2 class="section-heading">Friends of Moonb</h2>
        <div class="reviews__follow">
          <span class="reviews__follow-label">Follow Moonb</span>
          <a href="https://www.linkedin.com/company/moonb-creative/" class="reviews__follow-btn" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://www.instagram.com/moonb.creative/" class="reviews__follow-btn" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            Instagram
          </a>
        </div>
      </div>
      <p class="reviews__sub" data-reveal data-reveal-delay="1">See what people are saying.</p>
    </div>

    <!-- Row 1 — duplicated for seamless infinite scroll -->
    <div class="reviews__row" data-reveal data-reveal-delay="2">
      <div class="reviews__track">
        {[...reviews.slice(0, 4), ...reviews.slice(0, 4)].map((r, i) => (
          <div class="reviews__card" key={i}>
            <div class="reviews__card-header">
              <img class="reviews__avatar" src={r.avatar} alt={r.name} width="40" height="40" loading="lazy" />
              <div class="reviews__card-meta">
                <span class="reviews__card-name">{r.name}</span>
                <span class="reviews__card-role">{r.role}, {r.company}</span>
              </div>
            </div>
            <p class="reviews__card-quote">{r.quote}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 — scrolls opposite direction -->
    <div class="reviews__row" data-reveal data-reveal-delay="3">
      <div class="reviews__track">
        {[...reviews.slice(4, 8), ...reviews.slice(4, 8)].map((r, i) => (
          <div class="reviews__card" key={i}>
            <div class="reviews__card-header">
              <img class="reviews__avatar" src={r.avatar} alt={r.name} width="40" height="40" loading="lazy" />
              <div class="reviews__card-meta">
                <span class="reviews__card-name">{r.name}</span>
                <span class="reviews__card-role">{r.role}, {r.company}</span>
              </div>
            </div>
            <p class="reviews__card-quote">{r.quote}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════ BLOG PREVIEW — family.co 2-column ═══════ -->
  <section class="blog section">
    <div class="container">
      <div class="blog__header" data-reveal>
        <h2 class="section-heading">The latest from Moonb</h2>
        <a href="/blog" class="cta-link" style="color: var(--accent-green)">See all posts <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>

      <div class="blog__grid" data-reveal data-reveal-delay="1">
        {blogPosts.map((post) => (
          <a href={post.href} class="blog__card">
            <div class="placeholder placeholder--blog-lg"><span class="placeholder__label">Blog thumbnail</span></div>
            <span class="blog__card-date">{post.date}</span>
            <h3 class="blog__card-title">{post.title}</h3>
            <p class="blog__card-excerpt">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════ FAQ — family.co 2-column: heading LEFT, accordion RIGHT ═══════ -->
  <section class="faq section" id="faq">
    <div class="container">
      <div class="faq__inner">
        <div class="faq__left" data-reveal>
          <h2 class="faq__heading">Frequently Asked Questions</h2>
        </div>
        <div class="faq__right">
          <div class="faq__list" data-reveal data-reveal-delay="1">
            {faqs.map((faq, i) => (
              <div class="faq__item" data-faq-item>
                <button class="faq__question" data-faq-trigger aria-expanded="false">
                  <div class="faq__toggle" aria-hidden="true">
                    <div class="faq__toggle-h"></div>
                    <div class="faq__toggle-v"></div>
                  </div>
                  <span>{faq.q}</span>
                </button>
                <div class="faq__answer-wrap" data-faq-answer>
                  <div class="faq__answer"><p>{faq.a}</p></div>
                </div>
              </div>
            ))}
          </div>
          <a href="/faq" class="faq__more">See More FAQs <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="#FF5310" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════ CTA — after FAQ, before footer ═══════ -->
  <section class="final-cta section section--beige">
    <div class="container" data-reveal>
      <div class="final-cta__inner">
        <h2 class="final-cta__title">Ready to level up your creative?</h2>
        <p class="final-cta__sub">Book a call with us. No commitment, no pressure.</p>
        <a href="#" class="cta-link" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>Book a Call <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
  </section>


  <Footer />

  <!-- ═══════ VIDEO LIGHTBOX ═══════ -->
  <div class="lightbox" id="showreel-lightbox" aria-hidden="true">
    <div class="lightbox__backdrop" data-showreel-close></div>
    <div class="lightbox__content">
      <button class="lightbox__close" data-showreel-close aria-label="Close video">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="lightbox__video">
        <iframe id="showreel-iframe" width="100%" height="100%" style="border:none" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen title="Moonb Showreel"></iframe>
      </div>
    </div>
  </div>

  <script>
    const trigger = document.querySelector('[data-showreel-trigger]');
    const lightbox = document.getElementById('showreel-lightbox');
    const iframe = document.getElementById('showreel-iframe') as HTMLIFrameElement;
    const closeBtns = document.querySelectorAll('[data-showreel-close]');
    const vimeoSrc = 'https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&autoplay=1&title=0&byline=0&portrait=0';

    function openLightbox() {
      iframe.src = vimeoSrc;
      lightbox?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox?.setAttribute('aria-hidden', 'true');
      iframe.src = '';
      document.body.style.overflow = '';
    }

    trigger?.addEventListener('click', openLightbox);
    closeBtns.forEach(btn => btn.addEventListener('click', closeLightbox));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox?.getAttribute('aria-hidden') === 'false') closeLightbox();
    });
  </script>

</BaseLayout>
