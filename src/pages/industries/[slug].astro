  .svc__type-card:nth-child(2) .svc__type-num { color: var(--accent-blue); }
  .svc__type-card:nth-child(3) .svc__type-num { color: var(--accent-green); }
  .svc__type-card:nth-child(4) .svc__type-num { color: var(--accent); }
  .svc__type-card:nth-child(5) .svc__type-num { color: var(--accent-blue); }
  .svc__type-card:nth-child(6) .svc__type-num { color: var(--accent-green); }

