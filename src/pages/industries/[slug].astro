  .svc__step-num {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
  }

  .svc__step-content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .svc__step-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.3px;
    color: var(--heading);
    margin-bottom: 10px;
  }

  .svc__step-desc {
    font-size: 15px;
    line-height: 22px;
    color: var(--body);
