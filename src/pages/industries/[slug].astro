    margin-bottom: 4px;
  }

  .svc__compare-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
  }

  .svc__compare-cell--agency .svc__compare-value {
    color: var(--body-muted);
  }

  .svc__compare-vs {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 600;
    color: var(--body-muted);
    opacity: 0.4;
  }

  /* ── Work — thumbnail grid with play overlay ── */
  .svc__work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 40px;
  }

  .svc__work-card {
    display: block;
    text-decoration: none;
  }

  .svc__work-thumb {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #f0f0f0;
  }

  .svc__work-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease), filter 400ms ease;
  }

  .svc__work-card:hover .svc__work-thumb img {
    transform: scale(1.04);
    filter: brightness(0.85);
  }

  .svc__work-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 250ms ease;
  }

  .svc__work-play svg {
    width: 48px;
