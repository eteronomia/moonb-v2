    margin-top: 8px;
    font-size: 15px;
    color: var(--body-muted);
  }

  /* ── Differentiator — comparison style ── */
  .svc__diff-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .svc__diff-body {
    font-size: 17px;
    line-height: 27px;
    color: var(--body);
    margin-top: 16px;
  }

