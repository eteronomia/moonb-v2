  .svc__testimonial .svc__container {
    text-align: center;
  }

  .svc__quote-mark {
    font-family: var(--font-heading);
    font-size: 120px;
    font-weight: 600;
    color: var(--heading);
    line-height: 0.6;
    opacity: 0.08;
    margin-bottom: 0;
  }

  .svc__quote {
    max-width: 680px;
    margin: 0 auto;
  }

  .svc__quote-text {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 500;
