  }

  .svc__work-title {
    display: block;
    margin-top: 12px;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    color: var(--heading);
    transition: color 140ms ease;
  }

  .svc__work-card:hover .svc__work-title {
    color: var(--accent);
  }

  /* ── Process — horizontal timeline ── */
  .svc__process-header {
    margin-bottom: 64px;
  }

  .svc__process-track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    position: relative;
  }

  .svc__process-line {
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    height: 2px;
    background: var(--border);
  }

  .svc__step {
    position: relative;
    padding-right: 32px;
    display: flex;
    flex-direction: column;
  }

  .svc__step-dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--heading);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
    transition: transform 200ms ease;
