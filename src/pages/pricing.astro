---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

/* Real moonb.io copy + Superside layout structure */

const included = [
  'Dedicated Creative Director',
  'Dedicated Creative Team',
  'Design and Video Production',
  'Multiple Weekly Deliveries',
  'Weekly Calls',
  '24/7 Direct Slack or Teams Chat',
  'Support for Multiple Brands',
  'Full File Ownership',
];

const services = [
  'Video Production', 'Motion Graphics', 'Graphic Design', 'Animation',
  'Social Media Content', 'Explainer Videos', 'Brand Identity', 'Presentation Design',
  'Ad Creative', 'Product Demos', 'Internal & Training Videos', 'Commercial Video',
];

const logos = [
  { name: 'Dell', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/691db30dda671fbe474b31d3_Dell_Technologies_logo%201.svg' },
  { name: 'Intel', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/691dca52df40749fbcd69aa5_Intel.svg' },
  { name: 'Toyota', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bef26792b6bec0f6d184_TOYOTA.svg' },
  { name: 'Microsoft', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579be8830c130e5738402a3_MICROSOFT.svg' },
  { name: 'Nestlé', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579be9467c7bc3dd79a4a1a_NESTLE.svg' },
  { name: 'CyberArk', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bcdba5dd52502ff0dedc_CYBERARK.svg' },
  { name: 'Gnosis', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bcf1769cf9352c288511_GNOSIS.svg' },
  { name: 'GSK', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bd0d4b4dccecf622b297_GSK.svg' },
  { name: 'Politico', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bec73f22d633fb4192bb_POLITICO.svg' },
  { name: 'State Street', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bedfe6e64721668b66ab_STATESTREET.svg' },
];

const comparison = [
  { point: 'Better than hiring in-house', desc: 'No long hiring process. No salaries, benefits, or equipment. Get a full creative team producing from day one.' },
  { point: 'Beyond agencies & freelancers', desc: 'No unreliable freelancers. No agency markups. Your own dedicated team delivering world-class design and video every week.' },
  { point: 'Super fast onboarding', desc: 'Be onboarded and briefing your team within the first week. Most clients receive their first deliverable within 5-10 business days.' },
  { point: 'Quality content creation', desc: 'A team that learns your brand once and gets better with every deliverable. Consistent quality across every touchpoint.' },
];

const testimonials = [
  { quote: 'Moonb has become an essential part of our creative workflow. They were capable of adapting to fast delivery deadlines.', name: 'Rene Ugarte', role: 'Senior Producer', company: 'MOI', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821ba1672a50268f140277f_Rene%20Ugarte.avif' },
  { quote: 'Their creative flair and dedication to getting the animation and storytelling style right are impressive.', name: 'Marius Godo', role: 'Content Specialist', company: 'Gnosis', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b9dc6aa65e5d0a7ebe4e_Marius%20Godo.avif' },
  { quote: 'This was the best experience we have had with a large project like this. Highly recommend.', name: 'Josh Kirshman', role: 'Director of Marketing', company: 'Frame', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b8fbc31af3dd6d055791_Josh%20Kirshman.avif' },
  { quote: 'The team is highly creative, talented, and eager to deliver above and beyond expectations.', name: 'Jesse Jankewicz', role: 'Director of Video', company: 'Unobravo', avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b8619881dbbdd76b062d_Jesse%20Jankewitz.avif' },
];

const faqs = [
  { q: 'How does pricing work?', a: 'Moonb adapts to your needs. Whether you need a long-term creative partner or a single high-impact project, we offer flexible plans with predictable monthly pricing. Request a quote and we\'ll scope a plan that fits.' },
  { q: 'Is there a minimum commitment?', a: 'No long-term contracts required. You can cancel anytime. We also offer a 100% money-back guarantee for the first week — if you\'re not happy, you get a full refund, no questions asked.' },
  { q: 'What\'s included?', a: 'Every plan includes a dedicated Creative Director, a dedicated creative team, video and design production, multiple weekly deliveries, weekly calls, 24/7 Slack or Teams access, multi-brand support, and full file ownership.' },
  { q: 'Can I pause my plan?', a: 'Yes. If you need to take a break, you can pause and resume when you\'re ready. Your team and brand knowledge are preserved.' },
  { q: 'How fast will I receive deliverables?', a: 'Most deliverables are completed within 5–10 business days, depending on complexity. Your Creative Director manages the timeline and keeps you updated at every stage.' },
  { q: 'What if I need a one-off project?', a: 'Moonb works for both ongoing partnerships and single high-impact projects. Request a quote and we\'ll find the right approach for your needs.' },
  { q: 'Who owns the work?', a: 'You do. All working files, source files, and intellectual property are yours. No licensing fees, no usage restrictions.' },
  { q: 'How do I get started?', a: 'Request a quote. We\'ll schedule a quick call to understand your needs, scope the right plan, and get your dedicated team assembled. Most clients are onboarded within the first week.' },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moonb.io" },
    { "@type": "ListItem", "position": 2, "name": "Pricing" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
};
---

<BaseLayout title="Pricing | Moonb" description="Flexible plans for every business. Dedicated creative team with unlimited requests and revisions. Request a quote.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="pr">

    <!-- Hero -->
    <section class="pr__hero">
      <div class="pr__container">
        <h1 class="pr__title" data-reveal>A creative partner built to<br/><em>fuel your growth</em></h1>
        <p class="pr__subtitle" data-reveal data-reveal-delay="1">Whether you need a long-term creative partner or a single high-impact project, Moonb adapts to your needs.</p>
        <div class="pr__hero-actions" data-reveal data-reveal-delay="2">
          <a href="#" class="btn btn--primary" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>Request a Quote</a>
        </div>
      </div>
    </section>

    <!-- Included in all plans -->
    <section class="pr__included section">
      <div class="pr__container">
        <h2 class="pr__section-heading" data-reveal>Included in every plan</h2>
        <div class="pr__included-grid">
          {included.map((item, i) => (
            <div class="pr__included-item" data-reveal data-reveal-delay={String(Math.min(i, 4))}>
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M5 10L8.5 13.5L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
        <p class="pr__guarantee" data-reveal>Not loving it after a week? <strong>Get 100% back,</strong> no questions asked.</p>
      </div>
    </section>

    <!-- Trusted by -->
    <section class="pr__logos">
      <div class="pr__container">
        <p class="pr__logos-label" data-reveal>Trusted by leading brands</p>
        <div class="pr__logos-marquee">
          <div class="pr__logos-track">
            {[...logos, ...logos, ...logos].map((logo) => (
              <img src={logo.src} alt={logo.name} class="pr__logo" loading="lazy" />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Services grid — Superside style -->
    <section class="pr__services section section--beige">
      <div class="pr__container">
        <h2 class="pr__section-heading" data-reveal>12+ scalable creative services</h2>
        <p class="pr__section-sub" data-reveal>Access every creative skill you need from one dedicated team.</p>
        <div class="pr__services-grid">
          {services.map((s, i) => (
            <div class={`pr__service-chip pr__service-chip--accent-${(i % 4) + 1}`} data-reveal data-reveal-delay={String(Math.min(i, 5))}>
              {s}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- A better way — comparison cards -->
    <section class="pr__compare section">
      <div class="pr__container">
        <h2 class="pr__section-heading" data-reveal>A better way to get creative done</h2>
        <p class="pr__section-sub" data-reveal>No long hiring process and no unreliable freelancers. Your own dedicated team delivering world-class design and video every week.</p>
        <div class="pr__compare-grid">
          {comparison.map((c, i) => (
            <div class={`pr__compare-card pr__compare-card--accent-${(i % 4) + 1}`} data-reveal data-reveal-delay={String(i)}>
              <h3 class="pr__compare-title">{c.point}</h3>
              <p class="pr__compare-desc">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="pr__testimonials section section--beige">
      <div class="pr__container">
        <h2 class="pr__section-heading" data-reveal>What our clients say</h2>
        <div class="pr__testimonials-grid">
          {testimonials.map((t, i) => (
            <div class={`pr__testimonial pr__testimonial--accent-${(i % 4) + 1}`} data-reveal data-reveal-delay={String(i)}>
              <p class="pr__testimonial-quote">"{t.quote}"</p>
              <div class="pr__testimonial-footer">
                <img src={t.avatar} alt={t.name} class="pr__testimonial-avatar" width="40" height="40" loading="lazy" />
                <div>
                  <span class="pr__testimonial-name">{t.name}</span>
                  <span class="pr__testimonial-role">{t.role}, {t.company}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA banner -->
    <section class="pr__cta-banner">
      <div class="pr__container">
        <div class="pr__cta-inner" data-reveal>
          <div>
            <h2 class="pr__cta-title">Your creative team is ready.</h2>
            <p class="pr__cta-sub">Request a quote and get started within a week.</p>
          </div>
          <a href="#" class="btn btn--primary" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}' style="background: var(--white); color: var(--heading);">Request a Quote</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="pr__faq section section--beige" id="faq">
      <div class="pr__container">
        <div class="faq__inner">
          <div class="faq__left" data-reveal>
            <h2 class="faq__heading">Frequently Asked<br/><em>Questions</em></h2>
          </div>
          <div class="faq__right">
            <div class="faq__list" data-reveal>
              {faqs.map((faq) => (
                <div class="faq__item" data-faq-item>
                  <button class="faq__question" data-faq-trigger aria-expanded="false">
                    <div class="faq__toggle" aria-hidden="true">
                      <div class="faq__toggle-h"></div>
                      <div class="faq__toggle-v"></div>
                    </div>
                    <span>{faq.q}</span>
                  </button>
                  <div class="faq__answer-wrap" data-faq-answer>
                    <div class="faq__answer"><p>{faq.a}</p></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pre-footer CTA -->
    <section class="final-cta section section--beige">
      <div class="container" data-reveal>
        <div class="final-cta__inner">
          <h2 class="final-cta__title">Ready to level up your creative?</h2>
          <p class="final-cta__sub">No commitment, no pressure.</p>
          <a href="#" class="cta-link" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>Request a Quote <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>

<style>
  .pr__container {
    max-width: calc(var(--max-w) + 3rem);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ── */
  .pr__hero {
    padding-top: 160px;
    padding-bottom: 64px;
    text-align: center;
  }
  .pr__title {
    font-family: var(--font-heading);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -1.8px;
    line-height: 62px;
    color: var(--heading);
    max-width: 700px;
    margin: 0 auto;
  }
  .pr__title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .pr__subtitle {
    margin-top: 20px;
    font-size: 18px;
    line-height: 28px;
    color: var(--body);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .pr__hero-actions {
    margin-top: 32px;
  }

  /* ── Section headings ── */
  .pr__section-heading {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.8px;
    line-height: 38px;
    color: var(--heading);
    margin-bottom: 16px;
  }
  .pr__section-sub {
    font-size: 17px;
    line-height: 26px;
    color: var(--body);
    max-width: 520px;
    margin-bottom: 48px;
  }

  /* ── Included grid ── */
  .pr__included-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px 24px;
    margin-bottom: 32px;
  }
  .pr__included-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    color: var(--heading);
  }
  .pr__included-item:nth-child(1) svg { color: var(--accent); }
  .pr__included-item:nth-child(2) svg { color: var(--accent-blue); }
  .pr__included-item:nth-child(3) svg { color: var(--accent-green); }
  .pr__included-item:nth-child(4) svg { color: var(--accent-purple); }
  .pr__included-item:nth-child(5) svg { color: var(--accent); }
  .pr__included-item:nth-child(6) svg { color: var(--accent-blue); }
  .pr__included-item:nth-child(7) svg { color: var(--accent-green); }
  .pr__included-item:nth-child(8) svg { color: var(--accent-purple); }

  .pr__guarantee {
    font-size: 15px;
    color: var(--accent-green);
    font-weight: 500;
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid var(--gray-light);
  }
  .pr__guarantee strong {
    font-weight: 600;
  }

  /* ── Logos ── */
  .pr__logos {
    padding: 40px 0;
    border-top: 1px solid var(--gray-light);
    border-bottom: 1px solid var(--gray-light);
    overflow: hidden;
  }
  .pr__logos-label {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 500;
    color: var(--body-muted);
    text-align: center;
    margin-bottom: 24px;
  }
  .pr__logos-marquee {
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }
  .pr__logos-track {
    display: flex;
    align-items: center;
    gap: 56px;
    width: max-content;
    animation: pr-marquee 40s linear infinite;
    will-change: transform;
  }
  @keyframes pr-marquee {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-33.333%, 0, 0); }
  }
  .pr__logo {
    height: 28px;
    min-width: 70px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) brightness(0) opacity(0.5);
    flex-shrink: 0;
  }

  /* ── Services chips ── */
  .pr__services-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .pr__service-chip {
    padding: 10px 20px;
    border-radius: var(--r-pill);
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    background: var(--white);
    color: var(--heading);
    border: 1px solid var(--border);
    transition: all 200ms ease;
  }
  .pr__service-chip:hover { transform: translateY(-1px); }
  .pr__service-chip--accent-1:hover { border-color: var(--accent); color: var(--accent); background: rgba(255, 83, 16, 0.04); }
  .pr__service-chip--accent-2:hover { border-color: var(--accent-blue); color: var(--accent-blue); background: rgba(0, 102, 255, 0.04); }
  .pr__service-chip--accent-3:hover { border-color: var(--accent-green); color: var(--accent-green); background: rgba(0, 182, 122, 0.04); }
  .pr__service-chip--accent-4:hover { border-color: var(--accent-purple); color: var(--accent-purple); background: rgba(123, 97, 255, 0.04); }

  /* ── Comparison cards ── */
  .pr__compare-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .pr__compare-card {
    padding: 28px;
    border-radius: var(--r-xl);
    background: var(--beige);
    border-top: 3px solid transparent;
    transition: transform 200ms ease;
  }
  .pr__compare-card:hover { transform: translateY(-2px); }
  .pr__compare-card--accent-1 { border-top-color: var(--accent); }
  .pr__compare-card--accent-2 { border-top-color: var(--accent-blue); }
  .pr__compare-card--accent-3 { border-top-color: var(--accent-green); }
  .pr__compare-card--accent-4 { border-top-color: var(--accent-purple); }

  .pr__compare-title {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.2px;
    color: var(--heading);
    margin-bottom: 10px;
  }
  .pr__compare-desc {
    font-size: 14px;
    line-height: 21px;
    color: var(--body);
  }

  /* ── Testimonials ── */
  .pr__testimonials-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .pr__testimonial {
    padding: 28px;
    border-radius: var(--r-xl);
    background: var(--white);
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-top: 3px solid transparent;
  }
  .pr__testimonial--accent-1 { border-top-color: var(--accent); }
  .pr__testimonial--accent-2 { border-top-color: var(--accent-blue); }
  .pr__testimonial--accent-3 { border-top-color: var(--accent-green); }
  .pr__testimonial--accent-4 { border-top-color: var(--accent-purple); }

  .pr__testimonial-quote {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 500;
    line-height: 23px;
    color: var(--heading);
    flex: 1;
  }
  .pr__testimonial-footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .pr__testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }
  .pr__testimonial-name {
    display: block;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 600;
    color: var(--heading);
  }
  .pr__testimonial-role {
    display: block;
    font-size: 12px;
    color: var(--body-muted);
  }

  /* ── CTA banner ── */
  .pr__cta-banner {
    padding: 64px 0;
  }
  .pr__cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 48px 56px;
    background: var(--heading);
    border-radius: 20px;
  }
  .pr__cta-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.6px;
    color: var(--white);
  }
  .pr__cta-sub {
    margin-top: 6px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── FAQ heading italic ── */
  .faq__heading em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .pr__title { font-size: 38px; line-height: 44px; }
    .pr__included-grid { grid-template-columns: repeat(2, 1fr); }
    .pr__compare-grid { grid-template-columns: repeat(2, 1fr); }
    .pr__testimonials-grid { grid-template-columns: repeat(2, 1fr); }
    .pr__cta-inner {
      flex-direction: column;
      gap: 24px;
      text-align: center;
      padding: 40px 32px;
    }
  }

  @media (max-width: 480px) {
    .pr__title { font-size: 32px; line-height: 38px; }
    .pr__included-grid { grid-template-columns: 1fr; }
    .pr__compare-grid { grid-template-columns: 1fr; }
    .pr__testimonials-grid { grid-template-columns: 1fr; }
  }
</style>
