---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

/*
  Service page template — v2 redesign
  TODO: Replace hardcoded content with Sanity CMS fetch
*/

const service = {
  title: 'Corporate Video Production',
  slug: 'corporate-video-production',
  category: 'Video',
  heroHeading: 'Corporate Video Production',
  heroDescription: 'A dedicated creative team that produces corporate video continuously, from investor updates and executive messaging to recruitment content and internal communications.',
  seo: {
    title: 'Corporate Video Production | Moonb',
    description: 'Corporate video production from a dedicated creative team. Investor updates, executive messaging, recruitment, internal comms. Predictable monthly pricing.',
  },
  serviceTypes: [
    { title: 'Investor Relations', desc: 'Earnings call visuals, annual report videos, and shareholder updates that build confidence.' },
    { title: 'Executive Messaging', desc: 'Thought leadership content, town hall intros, and keynote support that feels authentic.' },
    { title: 'Recruitment & Employer Brand', desc: 'Culture videos, role spotlights, and onboarding content that attracts talent.' },
    { title: 'Internal Communications', desc: 'Policy updates, change management videos, and team announcements that actually get watched.' },
    { title: 'Training & Compliance', desc: 'Process walkthroughs, safety protocols, and regulatory training that holds attention.' },
    { title: 'Event & CSR', desc: 'Event recap packages, highlight reels, and corporate social responsibility stories.' },
  ],
  differentiator: {
    heading: 'The agency model is broken. We fixed it.',
    text: 'Legacy agencies scope and price each project individually — new briefs, new quotes, new onboarding every time. Moonb is a modern creative partner: one dedicated team, one monthly rate, no surprises. Your team learns your brand deeply and gets faster with every deliverable.',
    points: [
      { label: 'Legacy agency', value: 'New team every project', accent: false },
      { label: 'Moonb', value: 'Same dedicated team', accent: true },
      { label: 'Legacy agency', value: 'Per-project quotes & invoices', accent: false },
      { label: 'Moonb', value: 'One predictable monthly rate', accent: true },
      { label: 'Legacy agency', value: 'Weeks of back-and-forth', accent: false },
      { label: 'Moonb', value: '5–10 business days', accent: true },
    ],
  },
  stats: [
    { number: '500+', label: 'Videos produced' },
    { number: '5–10', label: 'Business days to deliver' },
    { number: '95%', label: 'Client retention' },
  ],
  process: [
    { number: '01', title: 'Get onboarded', desc: 'Sign up and meet your dedicated Creative Director. We learn your brand, your stakeholders, and your communication priorities.', detail: 'Takes about 30 minutes' },
    { number: '02', title: 'Request anything', desc: 'Submit briefs through our platform. Your CD manages the production pipeline, coordinates stakeholder reviews, and prioritizes the work.', detail: 'Unlimited requests' },
    { number: '03', title: 'Review and approve', desc: 'Receive polished deliverables within 5–10 business days. Revisions are included — no revision caps or change-order fees.', detail: 'No revision caps' },
  ],
  compound: {
    heading: 'The compound effect of a dedicated team',
    text: 'When the same team produces all your corporate video, they accumulate institutional knowledge about your brand, your executives, your audience, and what resonates. Scripts land faster because the team already understands your voice. Visual assets build on a growing library of approved elements. Stakeholder feedback loops shorten because the team anticipates preferences. Your corporate video program gets faster, more consistent, and more impactful with every month.',
  },
  work: [
    { title: 'Dell Technologies — Product Launch', thumb: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/65e7d8ec8c76e46b46c6b6f9_Portfolio%2001.webp', vimeo: 'https://vimeo.com/1084258404' },
    { title: 'Gnosis — Brand Story', thumb: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/65e7d8ed8c76e46b46c6b704_Portfolio%2002.webp', vimeo: 'https://vimeo.com/1084258404' },
    { title: 'Toyota — Recruitment Campaign', thumb: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/65e7d8ee8c76e46b46c6b70a_Portfolio%2003.webp', vimeo: 'https://vimeo.com/1084258404' },
    { title: 'Microsoft — Internal Comms', thumb: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/65e7d8ee8c76e46b46c6b710_Portfolio%2004.webp', vimeo: 'https://vimeo.com/1084258404' },
  ],
  testimonial: {
    quote: 'They\'ve delivered above and beyond.',
    name: 'Marius Godo',
    role: 'Digital Marketing & Content Specialist',
    company: 'Gnosis by Lesaffre',
    avatar: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6821b9dc6aa65e5d0a7ebe4e_Marius%20Godo.avif',
  },
  faqs: [
    { q: 'Can you produce corporate video for multi-location organizations?', a: 'Yes. Your team creates scalable production frameworks that maintain brand and quality consistency across regions and facilities. Location-specific content can be produced using animation and templated visual systems that keep every office\'s content aligned with the broader corporate identity.' },
    { q: 'How do you approach corporate video for publicly traded companies?', a: 'Your team understands the additional layer of scrutiny that comes with public company communications. Content is produced with awareness of disclosure requirements, quiet period considerations, and the need for legal review before publication. Your Creative Director coordinates with your investor relations and legal teams.' },
    { q: 'What types of corporate video generate the most internal engagement?', a: 'Executive updates that feel authentic rather than scripted, employee recognition and milestone celebration videos, and culture-focused content that showcases real team members consistently outperform generic corporate communications.' },
    { q: 'How do you handle confidential or sensitive corporate content?', a: 'Your team operates under strict confidentiality protocols. All project files are stored securely, access is limited to assigned team members, and NDAs are standard practice. For particularly sensitive content, your Creative Director coordinates directly with your legal or communications team.' },
    { q: 'How do you maintain brand consistency across different corporate video formats?', a: 'Your dedicated team builds a comprehensive brand guide at the start covering color palettes, typography, motion design language, voiceover tone, and music direction. Every video references this guide, so whether the output is a quarterly earnings summary or a recruitment piece, the identity stays consistent.' },
    { q: 'What makes corporate video different from other types of video content?', a: 'Corporate video serves internal and external business communication goals rather than direct advertising or entertainment. It includes investor updates, executive messaging, company culture pieces, internal announcements, and stakeholder communications. The tone, pacing, and visual approach are calibrated for professional audiences who expect clarity and credibility.' },
    { q: 'Can corporate video content be localized for international offices?', a: 'Yes. Your team produces master versions designed for localization from the start. Text overlays are kept in editable layers, voiceover scripts are written for easy translation, and culturally specific references are flagged during scripting.' },
    { q: 'Can corporate video support change management initiatives?', a: 'Yes. Video is one of the most effective tools for communicating organizational change because it conveys tone and intent in ways that email and memos cannot. Your team produces content that explains the why behind changes and provides a consistent message that reaches every employee.' },
  ],
  relatedServices: [
    { title: 'Marketing Video Production', slug: 'marketing-video-production', desc: 'Continuous marketing video from a dedicated creative team.' },
    { title: 'Branded Video Production', slug: 'branded-video-production', desc: 'Creating authentic connections through compelling video narratives.' },
    { title: 'Explainer Video Production', slug: 'explainer-video-production', desc: 'Clear, engaging explainer videos from a dedicated creative team.' },
  ],
  relatedBlogPosts: [
    { title: 'The complete guide to video production', slug: 'video-production-guide', date: '2026-02-02' },
    { title: 'Video marketing ROI: how to measure what matters', slug: 'video-marketing-roi', date: '2025-10-12' },
    { title: 'Corporate video production: everything you need to know', slug: 'corporate-video-production', date: '2025-08-15' },
    { title: 'How long is the average commercial?', slug: 'how-long-is-the-average-commercial', date: '2025-06-20' },
  ],
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const canonicalURL = new URL(`/services/${service.slug}`, Astro.site || 'https://moonb-v2.vercel.app');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "description": service.seo.description,
  "provider": { "@type": "Organization", "name": "Moonb", "url": "https://www.moonb.io" },
  "url": canonicalURL.toString(),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moonb.io" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.moonb.io/services" },
    { "@type": "ListItem", "position": 3, "name": service.title },
  ],
};

const faqSchema = service.faqs?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": service.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
} : null;

const logos = [
  { name: 'Dell', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/691db30dda671fbe474b31d3_Dell_Technologies_logo%201.svg' },
  { name: 'Intel', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/691dca52df40749fbcd69aa5_Intel.svg' },
  { name: 'Toyota', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bef26792b6bec0f6d184_TOYOTA.svg' },
  { name: 'Microsoft', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579be8830c130e5738402a3_MICROSOFT.svg' },
  { name: 'Nestlé', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579be9467c7bc3dd79a4a1a_NESTLE.svg' },
  { name: 'CyberArk', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bcdba5dd52502ff0dedc_CYBERARK.svg' },
  { name: 'Gnosis', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bcf1769cf9352c288511_GNOSIS.svg' },
  { name: 'State Street', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bedfe6e64721668b66ab_STATESTREET.svg' },
  { name: 'Politico', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bec73f22d633fb4192bb_POLITICO.svg' },
  { name: 'GSK', src: 'https://cdn.prod.website-files.com/64c4234d0856ecf478afcf82/6579bd0d4b4dccecf622b297_GSK.svg' },
];

export function getStaticPaths() {
  return [
    { params: { slug: 'corporate-video-production' } },
  ];
}
---

<BaseLayout title={service.seo.title} description={service.seo.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <div class="svc">

    <!-- Breadcrumbs -->
    <div class="svc__container">
      <nav class="svc__breadcrumbs" aria-label="Breadcrumb" data-reveal>
        <a href="/">Home</a>
        <span class="svc__sep">/</span>
        <a href="/services">Services</a>
        <span class="svc__sep">/</span>
        <span>{service.title}</span>
      </nav>
    </div>

    <!-- Hero — 2 column: text left, video right -->
    <section class="svc__hero" data-reveal>
      <div class="svc__container">
        <div class="svc__hero-inner">
          <div class="svc__hero-text">
            <span class="svc__cat">{service.category}</span>
            <h1 class="svc__title">{service.heroHeading}</h1>
            <p class="svc__desc">{service.heroDescription}</p>
            <a href="#work" class="btn btn--secondary">
              <svg class="play-icon" width="12" height="14" viewBox="0 0 12 14" fill="none" aria-hidden="true">
                <path d="M1 1.5C1 0.7 1.9 0.2 2.6 0.6L11 5.8C11.6 6.2 11.6 7.1 11 7.5L2.6 12.7C1.9 13.1 1 12.6 1 11.8V1.5Z" fill="currentColor" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
              </svg>
              See Selected Work
            </a>
          </div>
          <div class="svc__hero-video">
            <div class="svc__video-wrap">
              <iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&title=0&byline=0&portrait=0" width="100%" height="100%" style="border:none" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy" title="Moonb Showreel"></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Client logos — infinite scroll marquee -->
    <section class="svc__logos">
      <div class="svc__logos-marquee">
        <div class="svc__logos-track">
          {[...logos, ...logos, ...logos].map((logo) => (
            <img src={logo.src} alt={logo.name} class="svc__logo" loading="lazy" />
          ))}
        </div>
      </div>
    </section>

    <!-- What we produce — card grid with numbering -->
    <section class="svc__types section">
      <div class="svc__container">
        <div class="svc__types-header" data-reveal>
          <h2 class="svc__section-heading">What we produce</h2>
          <p class="svc__section-sub">Everything your corporate communications need, from one dedicated team.</p>
        </div>
        <div class="svc__types-grid">
          {service.serviceTypes.map((t, i) => (
            <div class="svc__type-card" data-reveal data-reveal-delay={String(Math.min(i, 5))}>
              <span class="svc__type-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="svc__type-title">{t.title}</h3>
              <p class="svc__type-desc">{t.desc}</p>
            </div>
          ))}
        </div>
        <p class="svc__types-more" data-reveal>And much more. If it's video for your business, we produce it.</p>
      </div>
    </section>

    <!-- Stats strip -->
    <section class="svc__stats">
      <div class="svc__container">
        <div class="svc__stats-grid" data-reveal>
          {service.stats.map((s) => (
            <div class="svc__stat">
              <span class="svc__stat-num">{s.number}</span>
              <span class="svc__stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Differentiator — comparison style -->
    <section class="svc__diff section section--beige">
      <div class="svc__container">
        <div class="svc__diff-inner">
          <div class="svc__diff-text" data-reveal>
            <h2 class="svc__section-heading">{service.differentiator.heading}</h2>
            <p class="svc__diff-body">{service.differentiator.text}</p>
          </div>
          <div class="svc__diff-compare" data-reveal data-reveal-delay="1">
            <div class="svc__compare-table">
              {[0, 1, 2].map((row) => (
                <div class="svc__compare-row">
                  <div class="svc__compare-cell svc__compare-cell--agency">
                    <span class="svc__compare-label">{service.differentiator.points[row * 2].label}</span>
                    <span class="svc__compare-value">{service.differentiator.points[row * 2].value}</span>
                  </div>
                  <div class="svc__compare-vs">vs</div>
                  <div class="svc__compare-cell svc__compare-cell--moonb">
                    <span class="svc__compare-label">{service.differentiator.points[row * 2 + 1].label}</span>
                    <span class="svc__compare-value">{service.differentiator.points[row * 2 + 1].value}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Work — thumbnail grid with play overlay -->
    <section class="svc__work section" id="work">
      <div class="svc__container">
        <h2 class="svc__section-heading" data-reveal>Selected work</h2>
        <div class="svc__work-grid">
          {service.work.map((w, i) => (
            <a href={w.vimeo} target="_blank" rel="noopener" class="svc__work-card" data-reveal data-reveal-delay={String(Math.min(i, 3))}>
              <div class="svc__work-thumb">
                <img src={w.thumb} alt={w.title} loading="lazy" />
                <div class="svc__work-play">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M8 5.14v13.72a1 1 0 001.5.86l11.04-6.86a1 1 0 000-1.72L9.5 4.28a1 1 0 00-1.5.86z" fill="#fff"/>
                  </svg>
                </div>
              </div>
              <span class="svc__work-title">{w.title}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Process — horizontal timeline with connecting line -->
    <section class="svc__process section section--beige">
      <div class="svc__container">
        <div class="svc__process-header" data-reveal>
          <h2 class="svc__section-heading">How it works</h2>
          <p class="svc__section-sub">From signup to first delivery in under two weeks.</p>
        </div>
        <div class="svc__process-track">
          <div class="svc__process-line" aria-hidden="true"></div>
          {service.process.map((s, i) => (
            <div class="svc__step" data-reveal data-reveal-delay={String(i)}>
              <div class="svc__step-dot">
                <span class="svc__step-num">{s.number}</span>
              </div>
              <div class="svc__step-content">
                <h3 class="svc__step-title">{s.title}</h3>
                <p class="svc__step-desc">{s.desc}</p>
                <span class="svc__step-detail">{s.detail}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial — large centered quote -->
    <section class="svc__testimonial section">
      <div class="svc__container" data-reveal>
        <div class="svc__quote-mark" aria-hidden="true">"</div>
        <blockquote class="svc__quote">
          <p class="svc__quote-text">{service.testimonial.quote}</p>
          <footer class="svc__quote-footer">
            <img src={service.testimonial.avatar} alt={service.testimonial.name} class="svc__quote-avatar" width="48" height="48" loading="lazy" />
            <div>
              <span class="svc__quote-name">{service.testimonial.name}</span>
              <span class="svc__quote-role">{service.testimonial.role}, {service.testimonial.company}</span>
            </div>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- Mid-page CTA banner -->
    <section class="svc__mid-cta">
      <div class="svc__container">
        <div class="svc__mid-cta-inner" data-reveal>
          <h2 class="svc__mid-cta-title">Ready to start producing?</h2>
          <a href="#" class="btn btn--primary" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>Book a Call</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    {service.faqs?.length > 0 && (
      <section class="svc__faq section section--beige" id="faq">
        <div class="svc__container">
          <div class="faq__inner">
            <div class="faq__left" data-reveal>
              <h2 class="faq__heading">Frequently Asked Questions</h2>
            </div>
            <div class="faq__right">
              <div class="faq__list" data-reveal>
                {service.faqs.map((faq) => (
                  <div class="faq__item" data-faq-item>
                    <button class="faq__question" data-faq-trigger aria-expanded="false">
                      <div class="faq__toggle" aria-hidden="true">
                        <div class="faq__toggle-h"></div>
                        <div class="faq__toggle-v"></div>
                      </div>
                      <span>{faq.q}</span>
                    </button>
                    <div class="faq__answer-wrap" data-faq-answer>
                      <div class="faq__answer"><p>{faq.a}</p></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Related services -->
    <section class="svc__related section">
      <div class="svc__container">
        <div class="svc__related-header" data-reveal>
          <h2 class="svc__section-heading">Related services</h2>
          <a href="/services" class="cta-link" style="color: var(--accent-purple)">All services <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
        <div class="svc__related-grid">
          {service.relatedServices.map((rs, i) => (
            <a href={`/services/${rs.slug}`} class="svc__related-card" data-reveal data-reveal-delay={String(i)}>
              <h3 class="svc__related-title">{rs.title}</h3>
              <p class="svc__related-desc">{rs.desc}</p>
              <span class="svc__related-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Related blog posts -->
    {service.relatedBlogPosts?.length > 0 && (
      <section class="svc__blog section section--beige">
        <div class="svc__container">
          <div class="svc__related-header" data-reveal>
            <h2 class="svc__section-heading">From the blog</h2>
            <a href="/blog" class="cta-link" style="color: var(--accent-green)">All posts <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
          <div class="svc__blog-grid">
            {service.relatedBlogPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="svc__blog-card" data-reveal>
                <span class="svc__blog-date">{formatDate(bp.date)}</span>
                <h3 class="svc__blog-title">{bp.title}</h3>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Pre-footer CTA -->
    <section class="final-cta section section--beige">
      <div class="container" data-reveal>
        <div class="final-cta__inner">
          <h2 class="final-cta__title">Ready to level up your creative?</h2>
          <p class="final-cta__sub">Book a call with us. No commitment, no pressure.</p>
          <a href="#" class="cta-link" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view"}'>Book a Call <svg width="18" height="15" viewBox="0 0 18 15" fill="none" aria-hidden="true"><path d="M1 7.5H17M17 7.5L11 1.5M17 7.5L11 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>

<style>
  /* ==========================================================================
     SERVICE PAGE — v2 redesign
     ========================================================================== */

  .svc__container {
    max-width: calc(var(--max-w) + 3rem);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Breadcrumbs */
  .svc__breadcrumbs {
    padding-top: 100px;
    margin-bottom: 40px;
    font-size: 13px;
    color: var(--body-muted);
  }

  .svc__breadcrumbs a {
    color: var(--body-muted);
    transition: color 140ms ease;
  }

  .svc__breadcrumbs a:hover { color: var(--heading); }

  .svc__sep {
    margin: 0 6px;
    opacity: 0.5;
  }

  .svc__breadcrumbs span:last-child { color: var(--body); }

  /* ── Hero — 2 column: text left, video right ── */
  .svc__hero {
    padding-bottom: 64px;
  }

  .svc__hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .svc__hero-video {
    width: 100%;
